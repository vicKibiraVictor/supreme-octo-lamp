# # ── RPC endpoints ─────────────────────────────────────────────────────────────
# # HTTP RPC for Base mainnet (Alchemy or Infura recommended)
# BASE_HTTP_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# # WebSocket RPC for Base mainnet (used for live event streaming)
# BASE_WS_RPC=wss://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ── Wallet ────────────────────────────────────────────────────────────────────
# 0x-prefixed private key of the searcher wallet that signs bundles
# This wallet needs enough ETH to cover gas on failed simulations (keep it minimal)
PRIVATE_KEY=0x...

# ── Contract addresses ────────────────────────────────────────────────────────
# Address of your deployed TriArbExecutor contract on Base
EXECUTOR_ADDR=0x...

# Address where arbitrage profit is sent after each successful trade
TREASURY_ADDR=0x...

BASE_HTTP_RPC=https://mainnet.base.org
BASE_WS_RPC=wss://mainnet.base.org